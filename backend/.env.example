PORT=5000
MONGODB_URI=mongodb://localhost:27017/portfolio

# Gmail SMTP — use an App Password, NOT your normal Gmail login password
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password (remove spaces if Google shows groups of 4)
# Gmail account used to SEND emails (must match the App Password account)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=abcdefghijklmnop

# WHO RECEIVES contact form messages — set any email you want (yours, friend, work, etc.)
RECEIVER_EMAIL=person-you-want@example.com
